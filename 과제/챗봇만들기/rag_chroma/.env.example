# 이 파일을 .env 로 복사해서 키를 채우세요:  cp .env.example .env

# --- 웹검색 RAG (무엇이든 물어보세요) — Gemini 2.5 Flash + Google 검색 ---
# Google AI Studio(https://aistudio.google.com/app/apikey)에서 발급
GEMINI_API_KEY=여기에_본인_Gemini_키
GEMINI_MODEL=gemini-2.5-flash
RAG_SOURCE=web          # web = Gemini 웹검색 / docs = 로컬 문서(ChromaDB)

# --- 로컬 문서 RAG 백엔드 (RAG_SOURCE=docs 일 때) ---
# LLM_BACKEND=local      # local / kogpt2 / finetuned / claude
# FINETUNED_MODEL_PATH=jjminu/kogpt2-koalpaca
# ANTHROPIC_API_KEY=sk-ant-...
