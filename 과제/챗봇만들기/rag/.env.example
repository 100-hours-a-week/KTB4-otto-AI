# 이 파일을 복사해서 .env 로 만들고 키를 채우세요:
#   cp .env.example .env
# 그런 다음 .env 안의 sk-ant-... 부분을 본인 키로 바꾸세요.

# Anthropic API 키 (https://console.anthropic.com 에서 발급)
# 이 값이 설정되면 챗봇이 자동으로 Claude 백엔드를 사용합니다.
ANTHROPIC_API_KEY=sk-ant-여기에-본인-키-붙여넣기

# (선택) 사용할 Claude 모델. 기본값은 비용 효율적인 sonnet.
# 더 똑똑한 답변을 원하면 claude-opus-4-8 로 바꾸세요.
CLAUDE_MODEL=claude-sonnet-4-6

# (선택) 백엔드 강제 지정: local 또는 claude. 보통은 비워두면 자동 선택됩니다.
# LLM_BACKEND=claude
