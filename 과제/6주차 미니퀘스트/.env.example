# Google AI Studio에서 발급: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# 사용할 모델 (기본값으로 충분)
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001

# 인덱스/문서 경로
DATA_DIR=./data
INDEX_DIR=./index

# 검색/청크 파라미터
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4
